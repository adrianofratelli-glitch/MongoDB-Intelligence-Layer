# MongoDB Atlas connection (never commit the real .env)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Admin boundary: quando definida, endpoints administrativos (model swap, resets,
# aprovação de denylist, area=all nos logs) exigem o header X-Admin-Key com este
# valor. Sem ela o PoV roda em modo demo aberto (warning no log).
# ADMIN_API_KEY=troque-por-um-segredo-forte

# Rate limit por identidade (requisições/minuto) nos endpoints que chamam LLM
# RATE_LIMIT_PER_MINUTE=30

# Origens CORS permitidas (CSV) — defina ao servir atrás de um domínio real
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Deadline do turno do agente (s) e teto de tokens por turno
# AGENT_TURN_TIMEOUT_SECONDS=120
# AGENT_MAX_TURN_TOKENS=60000

# Micro-cache do model_config (s). 0 = leitura a cada request (regra da demo)
# CONFIG_CACHE_SECONDS=0

# JWT: segredo de assinatura (sem ela: segredo efêmero por processo) e modo
# estrito (1 = request sem Bearer válido é rejeitada; 0 = fallback demo)
# JWT_SECRET=troque-por-um-segredo-forte
# AUTH_REQUIRED=0

# Logs em JSON estruturado (agregáveis por coletor) — 1 liga
# LOG_JSON=0
